#ifndef PATH_TRACER_VARIANT_NAMESPACE
#define PATH_TRACER_VARIANT_NAMESPACE pathtracer_render_variant
#define PATH_TRACER_VARIANT_NAMESPACE_DEFAULTED 1
#endif

#ifndef PATH_TRACER_ENTRYPOINT_NAME
#define PATH_TRACER_ENTRYPOINT_NAME mainPersistent
#define PATH_TRACER_ENTRYPOINT_NAME_DEFAULTED 1
#endif

#ifndef PATH_TRACER_ENTRYPOINT_POLYGON_METHOD
#define PATH_TRACER_ENTRYPOINT_POLYGON_METHOD PPM_APPROX_PROJECTED_SOLID_ANGLE
#define PATH_TRACER_ENTRYPOINT_POLYGON_METHOD_DEFAULTED 1
#endif

#if !PATH_TRACER_ENABLE_PERSISTENT
#error Persistent entrypoint requested while PATH_TRACER_ENABLE_PERSISTENT is disabled
#endif

[numthreads(RenderWorkgroupSize, 1, 1)]
[shader("compute")]
void PATH_TRACER_ENTRYPOINT_NAME(uint32_t3 threadID : SV_DispatchThreadID)
{
	PATH_TRACER_VARIANT_NAMESPACE::runPersistent(PATH_TRACER_ENTRYPOINT_POLYGON_METHOD);
}

#ifdef PATH_TRACER_ENTRYPOINT_POLYGON_METHOD_DEFAULTED
#undef PATH_TRACER_ENTRYPOINT_POLYGON_METHOD_DEFAULTED
#undef PATH_TRACER_ENTRYPOINT_POLYGON_METHOD
#endif
#ifdef PATH_TRACER_ENTRYPOINT_POLYGON_METHOD
#undef PATH_TRACER_ENTRYPOINT_POLYGON_METHOD
#endif
#ifdef PATH_TRACER_ENTRYPOINT_NAME_DEFAULTED
#undef PATH_TRACER_ENTRYPOINT_NAME_DEFAULTED
#undef PATH_TRACER_ENTRYPOINT_NAME
#endif
#ifdef PATH_TRACER_ENTRYPOINT_NAME
#undef PATH_TRACER_ENTRYPOINT_NAME
#endif
#ifdef PATH_TRACER_VARIANT_NAMESPACE_DEFAULTED
#undef PATH_TRACER_VARIANT_NAMESPACE_DEFAULTED
#undef PATH_TRACER_VARIANT_NAMESPACE
#endif
#ifdef PATH_TRACER_VARIANT_NAMESPACE
#undef PATH_TRACER_VARIANT_NAMESPACE
#endif
